{
  "expo": {
    "name": "Shinra Pocket",
    "slug": "shinra-pocket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0d0820"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shinrapocket.game",
      "infoPlist": {
        "UIBackgroundModes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0820"
      },
      "package": "com.shinrapocket.game"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
