{
  "expo": {
    "name": "Shinra Pocket",
    "slug": "shinra-pocket",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0d0820"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shinrapocket.game",
      "infoPlist": {
        "UIBackgroundModes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0820"
      },
      "package": "com.shinrapocket.game"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-localization",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "shinrapocket-prod"
      }
    }
  }
}
